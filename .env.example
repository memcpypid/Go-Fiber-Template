# Application
APP_ENV=development
APP_PORT=3000
APP_NAME="Go Fiber Template"

# Database (Postgres or MySQL)
DB_DRIVER=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASS=root
DB_NAME=go_fiber_db
DB_SSLMODE=disable

# JWT Config
JWT_SECRET=super_secret_key_change_in_production
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Default Admin Seed
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
