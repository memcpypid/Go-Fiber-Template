# ========================
# APPLICATION
# ========================
APP_ENV=development
APP_PORT=3000
APP_NAME="Go Fiber Template"

# ========================
# DATABASE (via PgBouncer)
# ========================
DB_DRIVER=postgres
DB_HOST=pgbouncer
DB_PORT=6432
DB_USER=root
DB_PASS=root
DB_NAME=go_fiber_db
DB_SSLMODE=disable

# ========================
# POSTGRES (Docker)
# ========================
POSTGRES_VERSION=16
POSTGRES_CONTAINER=evotes_postgres

# ========================
# PGBOUNCER
# ========================
PGBOUNCER_VERSION=latest
PGBOUNCER_CONTAINER=evotes_pgbouncer
PGBOUNCER_PORT=6432
PGBOUNCER_DB_HOST=postgres
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=20

# ========================
# PGADMIN
# ========================
PGADMIN_VERSION=latest
PGADMIN_CONTAINER=evotes_pgadmin
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# ========================
# JWT CONFIG
# ========================
JWT_SECRET=super_secret_key_change_in_production
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=168h

# ========================
# DEFAULT ADMIN SEED
# ========================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# ========================
# MINIO (Docker)
# ========================
MINIO_VERSION=latest
MINIO_CONTAINER=evotes_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ========================
# MINIO APP CONFIG
# ========================
MINIO_ENDPOINT=minio:9000
MINIO_DOMAIN_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123
MINIO_BUCKET_NAME=evotes-storage
MINIO_USE_SSL=false
MINIO_DOMAIN_USE_SSL=false
MINIO_EXPIRY=15m

# ========================
# GOOGLE OAUTH
# ========================
GOOGLE_OAUTH_CLIENT_ID=google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=google_client_secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:5173/oauth-success